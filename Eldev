; -*- mode: emacs-lisp; lexical-binding: t -*-

;; Eldev configuration for gastown.el

(eldev-use-package-archive 'gnu)
(eldev-use-package-archive 'nongnu)
(eldev-use-package-archive 'melpa)

;; Enable undercover.el for code coverage tracking
(eldev-use-plugin 'undercover)

;; Configure undercover to track coverage for all lisp/*.el files except tests
(setf eldev-undercover-fileset '("lisp/*.el" ":not" "lisp/test/*.el"))

;; Use codecov format and don't auto-send
(setf eldev-undercover-config '(codecov dontsend))

;; Fix transient edebug specs for undercover instrumentation
(defun gastown--fix-transient-edebug-specs ()
  "Override transient edebug specs to allow symbol references for groups."
  (def-edebug-spec transient-define-prefix
    (&define name lambda-list
             [&optional lambda-doc]
             [&rest keywordp sexp]
             [&rest [&or symbolp vectorp]]
             [&optional ("interactive" interactive) def-body]))
  (def-edebug-spec transient-define-group
    (&define name [&rest [&or symbolp vectorp]])))

(eval-after-load 'transient
  '(when (eq eldev-project-loading-mode 'source)
     (gastown--fix-transient-edebug-specs)))

(advice-add 'eldev-load-extra-dependencies :after
            (lambda (&rest _)
              (when (eq eldev-project-loading-mode 'source)
                (require 'transient nil t)
                (gastown--fix-transient-edebug-specs))))

(setq eldev-project-main-file "lisp/gastown.el")

;; Local dependency: beads.el (not on ELPA)
;; Add beads.el/lisp to load path directly
(push (expand-file-name "~/workspace/beads.el/lisp") load-path)

;; Runtime dependencies
(eldev-add-extra-dependencies 'runtime
                              '(:package transient :version "0.10.1"))
(eldev-add-extra-dependencies 'runtime
                              '(:package sesman :version "0.3.2"))
(eldev-add-extra-dependencies 'runtime
                              '(:package magit-section :version "3.3.0"))

;; Development dependencies
(eldev-add-extra-dependencies 'test
                              '(:package ert))
(eldev-add-extra-dependencies 'lint
                              '(:package package-lint :archive melpa))

;; Exclude build artifacts and worktrees
(setf eldev-standard-excludes
      `(:or ,eldev-standard-excludes "worktree/**" "share/**"))

;; Test files location
(setf eldev-test-fileset '("lisp/test/*.el"))

;; Load path includes lisp directory
(eldev-add-loading-roots 'build "lisp")
(eldev-add-loading-roots 'test "lisp")
(eldev-add-loading-roots 'test "lisp/test")

;; Test Dolt server isolation.
;;
;; Set BD_NO_DAEMON=1 unconditionally so ALL bd subprocesses spawned
;; during tests use file-backed storage and never connect to the
;; production Dolt server on port 3307.  This is the primary safety
;; net — individual test macros (gastown-test-with-dolt-server) also
;; remove it from process-environment to allow isolated integration
;; tests to connect to their own temporary server.
(setenv "BD_NO_DAEMON" "1")

;; Suite-level Dolt server (optional, faster for Dolt integration tests).
;; Set GASTOWN_TEST_DOLT=1 to start one isolated server for the whole suite:
;;   GASTOWN_TEST_DOLT=1 eldev test
;; Per-test isolation is also available via gastown-test-with-dolt-server.
;; Production Dolt on port 3307 is never touched.
(when (equal (getenv "GASTOWN_TEST_DOLT") "1")
  (require 'gastown-test)
  (gastown-test-suite-setup)
  (add-hook 'kill-emacs-hook #'gastown-test-suite-teardown))

;; Safety net: stop any per-test Dolt server on Emacs exit.
(add-hook 'kill-emacs-hook
          (lambda ()
            (when (and (fboundp 'gastown-test-stop-dolt-server)
                       (bound-and-true-p gastown-test--dolt-server-process))
              (gastown-test-stop-dolt-server))))
